# ─────────────────────────────────────────
#  Tenders AI — Environment Variables Example
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────

# LLM - Gemini
LLM_PROVIDER=gemini
GEMINI_API_KEY=
LLM_MODEL=gemini-2.0-flash
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Database - PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=tenders_ai
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/tenders_ai
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# App
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=
